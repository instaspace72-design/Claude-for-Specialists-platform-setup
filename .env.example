# ---------------------------------------------------------------------------
# Claude for Specialists - environment template
# Copy this file to ".env" and fill in real values. Never commit ".env".
# ---------------------------------------------------------------------------

# Airtable (course / lesson / exercise content)
AIRTABLE_API_KEY=pat_XXXXXXXXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Claude API (server-side chat proxy). ANTHROPIC_API_KEY also works.
CLAUDE_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXX
CLAUDE_MODEL=claude-sonnet-5

# Server
PORT=3001
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS)
FRONTEND_URL=http://localhost:8000,http://localhost:3000

# Optional: override the SQLite database location
# DB_PATH=./local.db
